OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
# Nexus Genesis production conversation runtime.
# Acceptance testing uses ElevenLabs Agents as the sole active Genesis conversation runtime.
# Keep API keys server-side only. Do not expose these values in browser UI or commits.
NEXUS_GENESIS_VOICE_RUNTIME=elevenlabs
NEXUS_ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENTS_TIMEOUT_MS=15000
# OpenAI Realtime failed the production gate and remains rollback-only.
# Leave disabled unless the owner explicitly performs a rollback test.
NEXUS_GENESIS_REALTIME_ENABLED=false
NEXUS_GENESIS_REALTIME_ROLLBACK_ENABLED=false
NEXUS_GENESIS_REALTIME_FALLBACK=blocked
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
# Nexus live knowledge / internet retrieval.
# Supported NEXUS_LIVE_KNOWLEDGE_PROVIDER values:
# - auto                   default; tries Tavily, Brave, Exa, then generic fallback
# - tavily                 requires TAVILY_API_KEY
# - brave                  requires BRAVE_SEARCH_API_KEY
# - exa                    requires EXA_API_KEY
# - generic                requires NEXUS_LIVE_KNOWLEDGE_API_KEY and NEXUS_LIVE_KNOWLEDGE_PROVIDER_ENDPOINT
# - openai-web-search      requires OPENAI_WEB_SEARCH_ENABLED=true and OPENAI_API_KEY
# - provider-endpoint      requires NEXUS_LIVE_KNOWLEDGE_PROVIDER_ENDPOINT
# Phase all-mode selector accepts auto, tavily, brave, exa, or generic. Legacy provider-endpoint/openai
# settings remain documented for older local experiments; generic uses the provider endpoint path.
# Optional generic API key fallback uses NEXUS_LIVE_KNOWLEDGE_API_KEY; provider-specific key names are preferred.
# Leave disabled unless the selected provider is configured and citations are required.
# Local setup examples:
# NEXUS_LIVE_KNOWLEDGE_PROVIDER=tavily with TAVILY_API_KEY
# NEXUS_LIVE_KNOWLEDGE_PROVIDER=brave with BRAVE_SEARCH_API_KEY
# NEXUS_LIVE_KNOWLEDGE_PROVIDER=exa with EXA_API_KEY
# NEXUS_LIVE_KNOWLEDGE_PROVIDER=generic with NEXUS_LIVE_KNOWLEDGE_PROVIDER_ENDPOINT and NEXUS_LIVE_KNOWLEDGE_API_KEY
NEXUS_LIVE_KNOWLEDGE_ENABLED=false
NEXUS_LIVE_KNOWLEDGE_PROVIDER=
NEXUS_LIVE_KNOWLEDGE_API_KEY=
NEXUS_LIVE_KNOWLEDGE_PROVIDER_ENDPOINT=
NEXUS_LIVE_KNOWLEDGE_MAX_RESULTS=5
NEXUS_LIVE_KNOWLEDGE_TIMEOUT_MS=9000
NEXUS_LIVE_KNOWLEDGE_SAFE_MODE=true
OPENAI_WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
# Nexus email provider activation.
# Supported NEXUS_EMAIL_PROVIDER values:
# - smtp      requires SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM
# - sendgrid  requires SENDGRID_API_KEY and SENDGRID_FROM_EMAIL
# Email sends require explicit confirmation. Healthcare/pharmacy/telehealth/mobile-clinic/RPM/RTM/physician-review packets require consent.
