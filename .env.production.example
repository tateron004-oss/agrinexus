# Nexus / AgriNexus production environment template
# Copy these names into the production host environment. Never commit real values.

# App
NODE_ENV=production
PORT=
NEXUS_PUBLIC_APP_URL=
NEXUS_ADMIN_EMAIL=
NEXUS_SUPPORT_EMAIL=

# Live Knowledge
NEXUS_LIVE_KNOWLEDGE_ENABLED=true
NEXUS_LIVE_KNOWLEDGE_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
NEXUS_LIVE_KNOWLEDGE_PROVIDER_ENDPOINT=
NEXUS_LIVE_KNOWLEDGE_API_KEY=
NEXUS_LIVE_KNOWLEDGE_MAX_RESULTS=5
NEXUS_LIVE_KNOWLEDGE_TIMEOUT_MS=9000
NEXUS_LIVE_KNOWLEDGE_SAFE_MODE=true

# Email
NEXUS_EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_REPLY_TO=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=true
SMTP_REPLY_TO=

# SMS / WhatsApp
NEXUS_COMMUNICATIONS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
TWILIO_STATUS_CALLBACK_URL=
NEXUS_SMS_ENABLED=true
NEXUS_MESSAGES_ENABLED=true
NEXUS_WHATSAPP_ENABLED=true

# Telehealth / Video
NEXUS_TELEHEALTH_PROVIDER=daily
DAILY_API_KEY=
DAILY_ROOM_DOMAIN=

NEXUS_TELEHEALTH_PROVIDER_NAME=
NEXUS_TELEHEALTH_INTAKE_URL=

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Real Provider Email Endpoints
NEXUS_PROVIDER_REVIEW_EMAIL=
NEXUS_PHARMACY_PROVIDER_MODE=email
NEXUS_PHARMACY_PROVIDER_NAME=
NEXUS_PHARMACY_REFERRAL_EMAIL=
NEXUS_PHARMACY_INTAKE_URL=
NEXUS_PHARMACY_SERVICE_REGION=
NEXUS_MOBILE_CLINIC_PROVIDER_MODE=email
NEXUS_MOBILE_CLINIC_PROVIDER_NAME=
NEXUS_MOBILE_CLINIC_REFERRAL_EMAIL=
NEXUS_MOBILE_CLINIC_INTAKE_URL=
NEXUS_MOBILE_CLINIC_SERVICE_REGION=
NEXUS_AGRONOMY_REVIEW_EMAIL=
NEXUS_MARKETPLACE_VENDOR_EMAIL=
NEXUS_LOGISTICS_PARTNER_EMAIL=
NEXUS_TRAINING_PARTNER_EMAIL=
NEXUS_ADMIN_ALERT_EMAIL=

# Real Provider SMS / WhatsApp Endpoints
NEXUS_PROVIDER_REVIEW_SMS_TO=
NEXUS_PROVIDER_REVIEW_WHATSAPP_TO=

NEXUS_PHARMACY_SMS_TO=
NEXUS_PHARMACY_WHATSAPP_TO=

NEXUS_MOBILE_CLINIC_SMS_TO=
NEXUS_MOBILE_CLINIC_WHATSAPP_TO=

NEXUS_AGRONOMY_SMS_TO=
NEXUS_AGRONOMY_WHATSAPP_TO=

NEXUS_MARKETPLACE_VENDOR_SMS_TO=
NEXUS_MARKETPLACE_VENDOR_WHATSAPP_TO=

NEXUS_LOGISTICS_SMS_TO=
NEXUS_LOGISTICS_WHATSAPP_TO=

NEXUS_TRAINING_PARTNER_SMS_TO=
NEXUS_TRAINING_PARTNER_WHATSAPP_TO=

# Production Smoke Test Controls
NEXUS_ENABLE_PRODUCTION_PROVIDER_SMOKE_SENDS=false
NEXUS_PRODUCTION_SMOKE_BASE_URL=
NEXUS_PRODUCTION_SMOKE_TEST_EMAIL_TO=
NEXUS_PRODUCTION_SMOKE_TEST_SMS_TO=
NEXUS_PRODUCTION_SMOKE_TEST_WHATSAPP_TO=
